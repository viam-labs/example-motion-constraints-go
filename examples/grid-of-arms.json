{
  "modules": [
    {
      "type": "registry",
      "name": "motion-demo",
      "module_id": "viam:example-motion-constraints-go",
      "version": "0.5.9"
    }
  ],
  "components": [
    {
      "name": "arm_a1", "api": "rdk:component:arm", "model": "rdk:builtin:simulated",
      "attributes": { "arm-model": "ur5e", "simulate-time": true },
      "frame": { "parent": "world", "translation": { "x": 1000, "y": 1000, "z": 0 } }
    },
    {
      "name": "arm_a2", "api": "rdk:component:arm", "model": "rdk:builtin:simulated",
      "attributes": { "arm-model": "ur5e", "simulate-time": true },
      "frame": { "parent": "world", "translation": { "x": -1000, "y": 1000, "z": 0 } }
    },
    {
      "name": "arm_a3", "api": "rdk:component:arm", "model": "rdk:builtin:simulated",
      "attributes": { "arm-model": "ur5e", "simulate-time": true },
      "frame": { "parent": "world", "translation": { "x": -1000, "y": -1000, "z": 0 } }
    },
    {
      "name": "arm_a4", "api": "rdk:component:arm", "model": "rdk:builtin:simulated",
      "attributes": { "arm-model": "ur5e", "simulate-time": true },
      "frame": { "parent": "world", "translation": { "x": 1000, "y": -1000, "z": 0 } }
    },
    {
      "name": "tip_a1", "api": "rdk:component:gripper", "model": "rdk:builtin:fake",
      "frame": { "parent": "arm_a1", "translation": { "x": 0, "y": 0, "z": 80 } }
    },
    {
      "name": "tip_a2", "api": "rdk:component:gripper", "model": "rdk:builtin:fake",
      "frame": { "parent": "arm_a2", "translation": { "x": 0, "y": 0, "z": 80 } }
    },
    {
      "name": "gripper_a3", "api": "rdk:component:gripper", "model": "rdk:builtin:fake",
      "frame": { "parent": "arm_a3", "translation": { "x": 0, "y": 0, "z": 80 } }
    },
    {
      "name": "gripper_a4", "api": "rdk:component:gripper", "model": "rdk:builtin:fake",
      "frame": { "parent": "arm_a4", "translation": { "x": 0, "y": 0, "z": 80 } }
    }
  ],
  "services": [
    {
      "name": "motion-playground",
      "type": "world_state_store",
      "model": "viam:example-motion-constraints-go:motion-playground",
      "depends_on": ["arm_a1", "arm_a2", "arm_a3", "arm_a4", "tip_a1", "tip_a2", "gripper_a3", "gripper_a4"],
      "attributes": {
        "arms": ["arm_a1", "arm_a2", "arm_a3", "arm_a4"],
        "preset_set": "ee_variations",
        "ee_frames": {
          "arm_a1": "tip_a1",
          "arm_a2": "tip_a2",
          "arm_a3": "gripper_a3",
          "arm_a4": "gripper_a4"
        },
        "loop": true,
        "interval_s": 2
      }
    }
  ]
}
