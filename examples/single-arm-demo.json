{
  "modules": [
    {
      "type": "registry",
      "name": "motion-demo",
      "module_id": "viam:example-motion-constraints-go"
    }
  ],
  "components": [
    {
      "name": "arm0",
      "api": "rdk:component:arm",
      "model": "rdk:builtin:fake",
      "attributes": { "arm-model": "ur5e" },
      "frame": {
        "parent": "world",
        "translation": { "x": 0, "y": 0, "z": 0 }
      }
    }
  ],
  "services": [
    {
      "name": "builtin-motion",
      "type": "motion",
      "model": "rdk:builtin:builtin"
    },
    {
      "name": "demo",
      "type": "world_state_store",
      "model": "viam:example-motion-constraints-go:planner",
      "depends_on": ["arm0", "builtin-motion"],
      "attributes": {
        "motion_service": "builtin-motion",
        "arms": ["arm0"],
        "loop": true,
        "interval_s": 3,
        "presets": ["single_arm_obstacle"]
      }
    }
  ]
}
